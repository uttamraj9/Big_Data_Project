pipeline {
    agent any

    parameters {
        choice(
            name: 'LOAD_MODE',
            choices: ['incremental', 'full'],
            description: 'Select the load mode: incremental (default) appends new data; full overwrites the curated table.'
        )
    }

    environment {
        VENV_DIR        = '/var/lib/jenkins/venvs/unit_testing_bd'
        EDGE_NODE       = 'ec2-user@13.41.167.97'
        SSH_KEY         = '/var/lib/jenkins/.ssh/cloudera_edge.pem'
        CURATED_SRC     = 'ON_PREM/data_ingestion_batch/src/curated_layer'
        REMOTE_TMP      = '/tmp/curated_layer_deploy'
    }

    stages {

        // ===================================================================
        // Stage 1 – Install Dependencies
        // ===================================================================
        stage('Install Dependencies') {
            steps {
                echo "Setting up Python virtual environment at ${VENV_DIR} …"
                sh """
                    if [ ! -d "${VENV_DIR}" ]; then
                        python3 -m venv "${VENV_DIR}"
                    fi
                    source "${VENV_DIR}/bin/activate"
                    pip install --upgrade pip
                    pip install -r ${CURATED_SRC}/requirements.txt
                """
            }
        }

        // ===================================================================
        // Stage 2 – Unit Tests
        // ===================================================================
        stage('Unit Tests') {
            steps {
                echo "Running pytest suite for the curated layer …"
                sh """
                    source "${VENV_DIR}/bin/activate"
                    pytest ${CURATED_SRC}/tests/ \
                        -v \
                        --tb=short \
                        --junitxml=test-results/curated_layer_tests.xml
                """
            }
            post {
                always {
                    junit 'test-results/curated_layer_tests.xml'
                }
            }
        }

        // ===================================================================
        // Stage 3 – Curated Load: Hive Raw → Hive Curated
        // ===================================================================
        stage('Curated Load: Hive Raw \u2192 Hive Curated') {
            steps {
                script {
                    def scriptName = (params.LOAD_MODE == 'full')
                        ? 'curated_full_load.sh'
                        : 'curated_incremental_load.sh'

                    echo "LOAD_MODE=${params.LOAD_MODE} → running ${scriptName}"

                    sh """
                        # Ensure remote tmp dir exists
                        ssh -i ${SSH_KEY} \
                            -o StrictHostKeyChecking=no \
                            ${EDGE_NODE} \
                            "mkdir -p ${REMOTE_TMP}/spark ${REMOTE_TMP}/scripts"

                        # Copy transformations and the selected load script
                        scp -i ${SSH_KEY} \
                            -o StrictHostKeyChecking=no \
                            ${CURATED_SRC}/spark/transformations.py \
                            ${CURATED_SRC}/spark/${scriptName.replace('curated_', '').replace('.sh', '.py')} \
                            ${EDGE_NODE}:${REMOTE_TMP}/spark/

                        scp -i ${SSH_KEY} \
                            -o StrictHostKeyChecking=no \
                            ${CURATED_SRC}/scripts/${scriptName} \
                            ${EDGE_NODE}:${REMOTE_TMP}/scripts/

                        # Execute the load script on the edge node
                        ssh -i ${SSH_KEY} \
                            -o StrictHostKeyChecking=no \
                            ${EDGE_NODE} \
                            "chmod +x ${REMOTE_TMP}/scripts/${scriptName} && \
                             bash ${REMOTE_TMP}/scripts/${scriptName}"
                    """
                }
            }
        }

        // ===================================================================
        // Stage 4 – Data Quality Check
        // ===================================================================
        stage('Data Quality Check') {
            steps {
                echo "Copying Great Expectations suite to edge node and running quality checks …"
                sh """
                    # Copy the GX suite script to the edge node
                    scp -i ${SSH_KEY} \
                        -o StrictHostKeyChecking=no \
                        ${CURATED_SRC}/data_quality/great_expectations_suite.py \
                        ${EDGE_NODE}:${REMOTE_TMP}/

                    # Run the quality check via spark-submit
                    ssh -i ${SSH_KEY} \
                        -o StrictHostKeyChecking=no \
                        ${EDGE_NODE} \
                        "spark-submit \
                            --master yarn \
                            --deploy-mode client \
                            --name curated-data-quality \
                            --conf spark.sql.hive.convertMetastoreParquet=false \
                            ${REMOTE_TMP}/great_expectations_suite.py"
                """
            }
        }
    }

    // =======================================================================
    // Post actions
    // =======================================================================
    post {
        success {
            echo "Pipeline completed successfully. LOAD_MODE=${params.LOAD_MODE}."
        }
        failure {
            echo "Pipeline FAILED. Review the console output and test results above."
        }
        always {
            deleteDir()
        }
    }
}
