<?xml version="1.0" encoding="UTF-8"?>
<!--
  workflow.xml - Bronze Layer Full Load
  ======================================
  Oozie workflow: PostgreSQL -> HDFS -> Hive external table (full replace).

  Run once during initial setup or whenever a full bronze refresh is needed.
  For daily incremental updates use the incremental_load workflow instead.

  FLOW
    [start]
      -> prepare-hdfs      (fs action)     create and chmod HDFS directory
      -> sqoop-full-import (sqoop action)  full import from PostgreSQL to HDFS
      -> create-hive-table (hive2 action)  drop and recreate Hive external table
      -> [end]

  REQUIRED PROPERTIES in job.properties
    nameNode, jobTracker, hdfs_target_dir,
    db_host, db_name, db_username, db_password, hiveserver2_url
-->
<workflow-app name="bronze-full-load" xmlns="uri:oozie:workflow:0.5">

    <start to="prepare-hdfs"/>

    <!-- Step 1: Create the HDFS bronze landing directory -->
    <action name="prepare-hdfs">
        <fs>
            <delete path="${hdfs_target_dir}"/>
            <mkdir  path="${hdfs_target_dir}"/>
            <chmod  path="${hdfs_target_dir}" permissions="777" dir-files="false"/>
        </fs>
        <ok    to="sqoop-full-import"/>
        <error to="fail"/>
    </action>

    <!-- Step 2: Sqoop full import from PostgreSQL into HDFS.
         Uses arg elements (not command) to avoid multi-line parsing issues.
         delete-target-dir ensures a clean full replace on every run.
    -->
    <action name="sqoop-full-import">
        <sqoop xmlns="uri:oozie:sqoop-action:0.2">
            <job-tracker>${jobTracker}</job-tracker>
            <name-node>${nameNode}</name-node>
            <arg>import</arg>
            <arg>--connect</arg>
            <arg>jdbc:postgresql://${db_host}:5432/${db_name}</arg>
            <arg>--username</arg>
            <arg>${db_username}</arg>
            <arg>--password</arg>
            <arg>${db_password}</arg>
            <arg>--table</arg>
            <arg>cc_fraud_trans</arg>
            <arg>--delete-target-dir</arg>
            <arg>--target-dir</arg>
            <arg>${hdfs_target_dir}</arg>
            <arg>--m</arg>
            <arg>1</arg>
            <arg>--as-textfile</arg>
        </sqoop>
        <ok    to="create-hive-table"/>
        <error to="fail"/>
    </action>

    <!-- Step 3: (Re)create the Hive external table via HiveServer2.
         The HQL script is uploaded to the workflow HDFS directory by deploy.sh.
         hdfs_target_dir is passed as a Hive variable so the LOCATION clause
         is resolved at runtime.
    -->
    <action name="create-hive-table">
        <hive2 xmlns="uri:oozie:hive2-action:0.2">
            <job-tracker>${jobTracker}</job-tracker>
            <name-node>${nameNode}</name-node>
            <jdbc-url>${hiveserver2_url}</jdbc-url>
            <script>create_bronze_hive_table.hql</script>
            <param>hdfs_target_dir=${hdfs_target_dir}</param>
        </hive2>
        <ok    to="end"/>
        <error to="fail"/>
    </action>

    <kill name="fail">
        <message>Bronze full load FAILED at [${wf:lastErrorNode()}]: ${wf:errorMessage(wf:lastErrorNode())}</message>
    </kill>

    <end name="end"/>

</workflow-app>
