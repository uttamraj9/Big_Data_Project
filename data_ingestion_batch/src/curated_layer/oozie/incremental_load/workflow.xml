<?xml version="1.0" encoding="UTF-8"?>
<workflow-app name="curated-incremental-load" xmlns="uri:oozie:workflow:0.5">

    <start to="spark-incremental-load"/>

    <!-- ================================================================
         Action 1: Run the Spark incremental-load job
         ================================================================ -->
    <action name="spark-incremental-load">
        <spark xmlns="uri:oozie:spark-action:0.2">
            <job-tracker>${jobTracker}</job-tracker>
            <name-node>${nameNode}</name-node>
            <master>yarn</master>
            <mode>client</mode>
            <name>curated-incremental-load</name>
            <jar>${spark_jar}</jar>
            <spark-opts>
                --conf spark.sql.hive.convertMetastoreParquet=false
                --conf spark.yarn.submit.waitAppCompletion=true
            </spark-opts>
            <arg>${hdfs_spark_dir}/incremental_load.py</arg>
            <file>${hdfs_spark_dir}/incremental_load.py#incremental_load.py</file>
            <file>${hdfs_spark_dir}/transformations.py#transformations.py</file>
        </spark>
        <ok to="data-quality-check"/>
        <error to="kill"/>
    </action>

    <!-- ================================================================
         Action 2: Run the Great Expectations data-quality check
         ================================================================ -->
    <action name="data-quality-check">
        <spark xmlns="uri:oozie:spark-action:0.2">
            <job-tracker>${jobTracker}</job-tracker>
            <name-node>${nameNode}</name-node>
            <master>yarn</master>
            <mode>client</mode>
            <name>curated-data-quality-check</name>
            <jar>${spark_jar}</jar>
            <spark-opts>
                --conf spark.sql.hive.convertMetastoreParquet=false
                --conf spark.yarn.submit.waitAppCompletion=true
            </spark-opts>
            <arg>${hdfs_spark_dir}/great_expectations_suite.py</arg>
            <file>${hdfs_spark_dir}/great_expectations_suite.py#great_expectations_suite.py</file>
        </spark>
        <ok to="end"/>
        <error to="kill"/>
    </action>

    <!-- ================================================================
         Kill node
         ================================================================ -->
    <kill name="kill">
        <message>Curated incremental-load workflow failed – action [${wf:lastErrorNode()}] error [${wf:errorCode(wf:lastErrorNode())}] message [${wf:errorMessage(wf:lastErrorNode())}]</message>
    </kill>

    <end name="end"/>

</workflow-app>
